{
  "name": "tianshu-shell",
  "version": "0.3.0",
  "private": true,
  "description": "个人桌面智能体：可拖动透明玻璃卡片 + 全局输入框（Electron，基于 opencode serve）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "compat": "node scripts/compat-check.mjs",
    "permcheck": "node scripts/permission-probe.mjs",
    "jsonschema": "node scripts/json-schema-probe.mjs",
    "orch:test": "node scripts/orchestrator-selftest.mjs",
    "orch:run": "node scripts/orchestrator-run.mjs",
    "mcp:browser": "node mcp/browser-mcp.mjs",
    "mcp:browser:test": "node mcp/selftest.mjs",
    "mcp:httpcap": "node mcp/httpcap-mcp.mjs",
    "mcp:httpcap:test": "node mcp/httpcap-selftest.mjs",
    "mcp:config": "node mcp/print-config.mjs"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.tianshu.shell",
    "productName": "个人桌面智能体",
    "files": [
      "main.js",
      "preload.js",
      "opencode.js",
      "orchestrator.js",
      "ui/**/*",
      "assets/**/*",
      "mcp/**/*",
      "package.json"
    ],
    "asarUnpack": ["mcp/**/*"],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "个人桌面智能体"
    },
    "portable": {
      "artifactName": "个人桌面智能体-便携版-${version}.exe"
    }
  }
}
