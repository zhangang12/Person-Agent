{
  "name": "BocomHermes-shell",
  "version": "0.6.6",
  "private": true,
  "description": "BocomHermes：可拖动透明玻璃卡片 + 全局输入框（Electron，基于 opencode serve）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:all": "electron-builder --win --mac",
    "compat": "node scripts/compat-check.mjs",
    "permcheck": "node scripts/permission-probe.mjs",
    "jsonschema": "node scripts/json-schema-probe.mjs",
    "mail:test": "node scripts/mail-parse-selftest.mjs",
    "tool:test": "node scripts/tool-part-selftest.mjs",
    "compact:test": "node scripts/recorder-compact-selftest.mjs",
    "card:ui:test": "node scripts/card-ui-selftest.mjs",
    "knowledge:test": "node scripts/knowledge-selftest.mjs",
    "scope:test": "node scripts/writescope-selftest.mjs",
    "session:test": "node scripts/session-selftest.mjs",
    "modelroute": "node scripts/model-route-probe.mjs",
    "mcp:browser": "node mcp/browser-mcp.mjs",
    "mcp:browser:test": "node mcp/selftest.mjs",
    "mcp:httpcap": "node mcp/httpcap-mcp.mjs",
    "mcp:httpcap:test": "node mcp/httpcap-selftest.mjs",
    "mcp:repro": "node mcp/repro-mcp.mjs",
    "mcp:mail": "node mcp/mail-mcp.mjs",
    "mcp:repro:test": "node mcp/repro-selftest.mjs",
    "repro:e2e": "electron scripts/e2e-repro-test.mjs",
    "bars:e2e": "electron scripts/e2e-bars.mjs",
    "mcp:config": "node mcp/print-config.mjs"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.8.0",
    "xlsx": "^0.18.5",
    "mysql2": "^3.11.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.BocomHermes.shell",
    "productName": "BocomHermes",
    "files": [
      "main.js",
      "preload.js",
      "opencode.js",
      "src/**/*",
      "ui/**/*",
      "assets/**/*",
      "mcp/**/*",
      "package.json"
    ],
    "asarUnpack": ["mcp/**/*"],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "BocomHermes"
    },
    "portable": {
      "artifactName": "BocomHermes-便携版-${version}.exe"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "BocomHermes ${version}",
      "artifactName": "BocomHermes-${version}-${arch}.dmg"
    }
  }
}
